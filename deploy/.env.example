# mixle-mlops environment — copy to deploy/.env and edit. All vars are prefixed MIXLE_
# (read by mixle_mlops/config.py:Settings, env_prefix="MIXLE_"). Compose-only vars
# (MIXLE_GIT, OLLAMA_PORT, POSTGRES_*) are documented at the bottom.

# ---------------------------------------------------------------------------
# Core platform
# ---------------------------------------------------------------------------
# Storage/auth backend: "local" (SQLite + filesystem) or "cloud" (Postgres + S3).
MIXLE_DEPLOYMENT=local

# Pepper for password/token hashing. CHANGE THIS — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
MIXLE_SECRET_KEY=change-me-please-generate-a-real-secret

# Writable data dir (inside the container this is the mounted volume; leave as /data).
MIXLE_DATA_DIR=/data

# Require an API key / session on protected routes. Set false ONLY for local dev.
MIXLE_REQUIRE_AUTH=true

# Gateway listen port (host side). Container always serves on 8000.
MIXLE_PORT=8000

# ---------------------------------------------------------------------------
# Default LLM backend (any OpenAI-compatible server; Ollama by default)
# ---------------------------------------------------------------------------
# Points at the `ollama` compose service. For an external vLLM/llama.cpp/hosted
# OpenAI-compatible endpoint, set this to that server's /v1 URL.
MIXLE_LLM_BASE_URL=http://ollama:11434/v1
MIXLE_LLM_API_KEY=ollama

# JSON list of model ids to expose from the LLM backend. Pull them in Ollama first:
#   docker compose -f deploy/docker-compose.yml exec ollama ollama pull llama3.2
MIXLE_LLM_MODELS=["llama3.2"]

# Default model when a request omits one. "echo" needs no backend (always available).
MIXLE_DEFAULT_MODEL=echo

# ---------------------------------------------------------------------------
# Cloud mode (only when MIXLE_DEPLOYMENT=cloud)
# ---------------------------------------------------------------------------
# Required in cloud mode. Use the Postgres service from the `cloud` compose profile:
# MIXLE_DATABASE_URL=postgresql+psycopg://mixle:mixle@postgres:5432/mixle
MIXLE_DATABASE_URL=

# Optional object store for blobs in cloud mode.
# MIXLE_S3_BUCKET=
# MIXLE_S3_ENDPOINT=

# ---------------------------------------------------------------------------
# Compose-only knobs (not read by the app)
# ---------------------------------------------------------------------------
# Git ref for the mixle core installed into the image at build time.
MIXLE_GIT=git+https://github.com/gmboquet/mixle@main
# Host ports for the side services.
OLLAMA_PORT=11434
POSTGRES_PORT=5432
# Postgres credentials for the `cloud` profile.
POSTGRES_USER=mixle
POSTGRES_PASSWORD=mixle
POSTGRES_DB=mixle
